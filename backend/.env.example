# Copy to .env — ONE active DB_URL line only, no spaces around =

# MongoDB Atlas (recommended): Atlas → Connect → Drivers → copy connection string, include database name /hussain
DB_URL=

# Local MongoDB only if installed and running on this machine:
# DB_URL=mongodb://127.0.0.1:27017/hussain

# Public URL of this API (local: http://localhost:3000, production: https://your-service.onrender.com)
BACKEND_URL=

# Frontend URL (local: http://localhost:5173, production: your Vercel URL, no trailing slash)
FRONT_APP_URL_DEV=

PORT=3000

# Long random strings (e.g. openssl rand -hex 32)
JWT_SECRET=
PASSPORT_SECRET=

# Google OAuth: console.cloud.google.com → Credentials → OAuth client
# Redirect URI: {BACKEND_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth: github.com/settings/developers
# Callback URL: {BACKEND_URL}/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Email on Render free tier: use SendGrid (SMTP ports 587/465 are blocked)
# SendGrid: create API key + verify sender email at sendgrid.com
SENDGRID_API_KEY=
MAIL_FROM=

# SMTP alternative (local dev or Render paid): Gmail needs an App Password, not your normal password
MAIL_HOST=
MAIL_PORT=
MAIL_EMAIL=
MAIL_PASSWORD=
