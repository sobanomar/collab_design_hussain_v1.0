# Copy this file to .env and replace dummy values with your own.
# ONE active DB_URL line only — no spaces around =

# MongoDB Atlas (recommended)
DB_URL=mongodb+srv://collab_user:YourStrongPassword123@cluster0.abc123.mongodb.net/hussain?retryWrites=true&w=majority

# Local MongoDB (only if MongoDB is installed and running on this machine)
# DB_URL=mongodb://127.0.0.1:27017/hussain

# App URLs
BACKEND_URL=http://localhost:3000
FRONT_APP_URL_DEV=http://localhost:5173
PORT=3000

# Auth secrets — use long random strings in production (e.g. openssl rand -hex 32)
JWT_SECRET=change_me_jwt_secret_min_32_chars_abc123xyz
PASSPORT_SECRET=change_me_passport_secret_min_32_chars_def456uvw

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=123456789012-abcdefghijklmnopqrstuvwxyz123456.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-dummy_google_client_secret_replace_me

# GitHub OAuth — https://github.com/settings/developers
GITHUB_CLIENT_ID=Iv1.0123456789abcdef
GITHUB_CLIENT_SECRET=ghp_dummy_github_oauth_secret_replace_me_0123456789

# Email — Render FREE tier blocks SMTP (ports 587/465). Use SendGrid in production:
SENDGRID_API_KEY=SG.dummy_sendgrid_api_key_replace_me.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MAIL_FROM=collabdesign@example.com

# SMTP (local dev or Render paid) — comment out SENDGRID_* above if using SMTP only
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_EMAIL=your.name@gmail.com
MAIL_PASSWORD=your_16_char_gmail_app_password
